PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ems_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace_with_another_long_random_secret
REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173

# Initial Admin Credentials (for db:init production setup)
# If password is left blank, a random one will be generated and printed during setup.
INITIAL_ADMIN_EMAIL=admin@ems.com
INITIAL_ADMIN_PASSWORD=change_this_to_a_secure_password_123!
